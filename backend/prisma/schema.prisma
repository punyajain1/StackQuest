generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────

enum GameMode {
  judge
  score_guesser
  answer_arena
  multiple_choice
  tag_guesser
}

enum Difficulty {
  easy
  medium
  hard
}

// ─── Models ──────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  isGuest      Boolean  @default(false) @map("is_guest")
  xp           Int      @default(0)
  level        Int      @default(1)
  streakRecord Int      @default(0) @map("streak_record")
  totalGames   Int      @default(0) @map("total_games")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastActive   DateTime @default(now()) @map("last_active") @db.Timestamptz

  gameSessions       GameSession[]
  leaderboardEntries LeaderboardEntry[]

  @@map("users")
}

model GameSession {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String?   @map("user_id") @db.Uuid
  mode           GameMode
  tag            String?
  score          Int       @default(0)
  accuracy       Float     @default(0)
  streakPeak     Int       @default(0) @map("streak_peak")
  questionsCount Int       @default(0) @map("questions_count")
  correctCount   Int       @default(0) @map("correct_count")
  durationSecs   Int       @default(0) @map("duration_secs")
  isDaily        Boolean   @default(false) @map("is_daily")
  dailyDate      DateTime? @map("daily_date") @db.Date
  xpEarned       Int       @default(0) @map("xp_earned")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user               User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  questionAnswers    QuestionAnswer[]
  leaderboardEntries LeaderboardEntry[]

  @@map("game_sessions")
}

model QuestionAnswer {
  id              String   @id @default(uuid()) @db.Uuid
  sessionId       String   @map("session_id") @db.Uuid
  soQuestionId    Int      @map("so_question_id")
  mode            GameMode
  playerAnswer    String?  @map("player_answer")
  playerChoice    String?  @map("player_choice")
  correct         Boolean  @default(false)
  scoreEarned     Int      @default(0) @map("score_earned")
  xpEarned        Int      @default(0) @map("xp_earned")
  similarityScore Float?   @map("similarity_score")
  timeTakenMs     Int      @default(0) @map("time_taken_ms")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("question_answers")
}

model SoQuestionCache {
  questionId       Int        @id @map("question_id")
  title            String
  body             String
  bodyMarkdown     String     @map("body_markdown")
  tags             String[]
  score            Int        @default(0)
  answerCount      Int        @default(0) @map("answer_count")
  acceptedAnswerId Int?       @map("accepted_answer_id")
  topAnswerText    String?    @map("top_answer_text")
  topAnswerScore   Int?       @map("top_answer_score")
  viewCount        Int        @default(0) @map("view_count")
  difficulty       Difficulty @default(medium)
  isAnswered       Boolean    @default(false) @map("is_answered")
  creationDate     DateTime   @map("creation_date") @db.Timestamptz
  lastFetched      DateTime   @default(now()) @map("last_fetched") @db.Timestamptz

  @@map("so_question_cache")
}

model LeaderboardEntry {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  username   String
  score      Int
  mode       GameMode
  tag        String?
  periodWeek String   @map("period_week")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("leaderboard_entries")
}

model DailyChallenge {
  id          String   @id @default(uuid()) @db.Uuid
  date        DateTime @unique @db.Date
  questionIds Int[]    @map("question_ids")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("daily_challenges")
}
