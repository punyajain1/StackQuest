# ========================
# Server
# ========================
PORT=3000
NODE_ENV=development

# ========================
# PostgreSQL
# ========================
DATABASE_URL=postgresql://user:password@host:5432/stackquest?sslmode=require

# ========================
# JWT
# ========================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-16-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-also-min-16-chars
JWT_REFRESH_EXPIRES_IN=30d

# ========================
# Stack Overflow API
# ========================
# Leave blank to use free tier (300 req/day)
# Register at https://stackapps.com/ for 10,000 req/day
SO_API_KEY=
SO_API_BASE=https://api.stackexchange.com/2.3
SO_SITE=stackoverflow

# ========================
# Game Config
# ========================
QUESTION_POOL_MIN=50
QUESTION_POOL_REFRESH_HOURS=6
CACHE_TTL_SECONDS=86400

# ========================
# Duel Config
# ========================
DUEL_ROUNDS=5
DUEL_TIME_LIMIT_SECS=30
DAILY_QUESTION_COUNT=10
