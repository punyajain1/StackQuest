# ========================
# Server
# ========================
PORT=3000
NODE_ENV=development

# ========================
# PostgreSQL — Neon.tech
# ========================
# Get your connection string from: https://console.neon.tech
# Project → Connection Details → Connection string
# Make sure "Pooled connection" is ON for best performance
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require

# To switch to local Postgres later, just replace with:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/stackquest

# ========================
# JWT
# ========================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# ========================
# Stack Overflow API
# ========================
# Leave blank to use free tier (300 req/day)
# Register at https://stackapps.com/ for 10,000 req/day
SO_API_KEY=
SO_API_BASE=https://api.stackexchange.com/2.3
SO_SITE=stackoverflow

# ========================
# HuggingFace
# ========================
# Free tier — get key at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model used for sentence similarity
HF_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ========================
# Game Config
# ========================
QUESTION_POOL_MIN=50
QUESTION_POOL_REFRESH_HOURS=6
CACHE_TTL_SECONDS=86400
